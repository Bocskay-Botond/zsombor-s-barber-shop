# ─── Zsombor's Barber Shop — környezeti változók ───────────────────────────────
# Másold át .env néven, vagy állítsd be ezeket a hosting felületén.
# (A .env fájl gitignore-olt, soha ne kerüljön verziókezelésbe.)

# A port, amin a szerver figyel (alapértelmezett: 3000)
PORT=3000

# ÉLES ÜZEMBEN KÖTELEZŐ: hosszú, véletlen titok az admin tokenek aláírásához.
# Generálás:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Ha üresen hagyod, az app automatikusan generál egyet a .jwtsecret fájlba
# (egy szervernél rendben van, de éles üzemhez érdemes itt explicit beállítani).
JWT_SECRET=

# Opcionális: az admin kezdő jelszava az ELSŐ indításkor (min. 6 karakter).
# Ha üres, az app véletlen jelszót generál és egyszer kiírja a konzolra.
ADMIN_PASSWORD=

# Állítsd "true"-ra CSAK akkor, ha reverse proxy (nginx, Caddy, stb.) mögött fut,
# hogy a kliens IP-k helyesen jöjjenek a rate-limithez. Közvetlen kitettségnél hagyd üresen.
TRUST_PROXY=
